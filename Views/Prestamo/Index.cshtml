@model IEnumerable<BookstoreSistem.Models.Prestamo>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Message"]
                </div>
            }

            <table class="table text-center align-middle">
                <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Usuario</th>
                    <th scope="col">Libro</th>
                    <th scope="col">Fecha de Préstamo</th>
                    <th scope="col">Fecha de Devolución</th>
                    <th scope="col">Acciones</th>
                </tr>
                </thead>

                <tbody>
                @foreach (var prestamo in Model)
                {
                    <tr>
                        <th scope="row">@prestamo.Id</th>
                        <td>@prestamo.Usuario?.Nombre @prestamo.Usuario?.Apellido</td>
                        <td>@prestamo.Libro?.Titulo</td>
                        <td>@prestamo.FechaPrestamo.ToShortDateString()</td>
                        <td>@(prestamo.FechaDevolucion?.ToShortDateString() ?? "No devuelto")</td>
                        <td>
                            <a class="btn btn-primary btn-sm"
                               asp-action="Details"
                               asp-route-id="@prestamo.Id">Ver</a>

                            @if (prestamo.FechaDevolucion == null)
                            {
                                <a class="btn btn-success btn-sm"
                                   asp-action="Devolver"
                                   asp-route-id="@prestamo.Id">Devolver</a>
                            }

                            <a class="btn btn-warning btn-sm"
                               asp-action="Edit"
                               asp-route-id="@prestamo.Id">Editar</a>

                            <a class="btn btn-danger btn-sm"
                               asp-action="Destroy"
                               asp-route-id="@prestamo.Id">Eliminar</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>

            <div class="d-flex justify-content-end mt-3">
                <a asp-action="Create" class="btn btn-success">
                    + Agregar Nuevo Préstamo
                </a>
            </div>

        </div>
    </div>
</div>