@model BookstoreSistem.Models.Prestamo

<div class="content vh-100 d-flex align-items-center justify-content-center">
    <div class="row">
        <div class="col-lg-12 shadow shadow-lg p-5 justify-content-center align-items-center d-flex flex-column">
            <h2>Editar Préstamo</h2>
            <form asp-action="Edit" method="post" class="form d-flex flex-column align-items-center justify-content-center">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="form-group mt-3">
                    <label asp-for="UsuarioId">Usuario</label>
                    <select asp-for="UsuarioId" class="form-control" asp-items="ViewBag.Usuarios"></select>
                </div>

                <div class="form-group mt-3">
                    <label asp-for="LibroId">Libro</label>
                    <select asp-for="LibroId" class="form-control" asp-items="ViewBag.Libros"></select>
                </div>

                <div class="form-group mt-3">
                    <label asp-for="FechaPrestamo"></label>
                    <input asp-for="FechaPrestamo" class="form-control" type="datetime-local" />
                </div>

                <div class="form-group mt-3">
                    <label asp-for="FechaDevolucion"></label>
                    <input asp-for="FechaDevolucion" class="form-control" type="datetime-local" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Actualizar</button>
                </div>
            </form>
        </div>
    </div>
</div>