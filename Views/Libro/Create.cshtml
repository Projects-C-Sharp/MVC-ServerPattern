@model BookstoreSistem.Models.Libro

<div class="content vh-100 d-flex align-items-center justify-content-center">
    <div class="row">
        <div class="col-lg-12 shadow shadow-lg p-5 d-flex flex-column align-items-center">

            <h2>Crear Libro</h2>
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Message"]
                </div>
            }

            <form asp-action="Create" method="post" class="form d-flex flex-column align-items-center justify-content-center">

                @Html.AntiForgeryToken()

                <div class="form-group mt-3 w-100">
                    <label asp-for="Titulo"></label>
                    <input asp-for="Titulo" class="form-control" placeholder="Ingrese título" />
                </div>

                <div class="form-group mt-3 w-100">
                    <label asp-for="Autor"></label>
                    <input asp-for="Autor" class="form-control" placeholder="Ingrese autor" />
                </div>

                <div class="form-group mt-3 w-100">
                    <label asp-for="Genero"></label>
                    <input asp-for="Genero" class="form-control" placeholder="Ingrese género" />
                </div>

                <div class="form-group mt-3 w-100">
                    <label asp-for="AnioPublicacion"></label>
                    <input asp-for="AnioPublicacion" class="form-control" placeholder="Ingrese año de publicación" />
                </div>

                <div class="mt-4 d-flex gap-3">
                    <button type="submit" class="btn btn-primary">Crear</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>

            </form>

        </div>
    </div>
</div>