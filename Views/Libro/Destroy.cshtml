@model BookstoreSistem.Models.Libro

<div class="container-fluid vh-100 p-5 d-flex flex-column align-items-center justify-content-center">

    <div class="row w-75">
        <div class="col-lg-12 shadow shadow-lg p-5 d-flex flex-column align-items-center">

            <h2 class="mb-4 text-danger">Eliminar Libro</h2>

            <div class="mb-4 w-100">
                <p><strong>Id:</strong> @Model.Id</p>
                <p><strong>Título:</strong> @Model.Titulo</p>
                <p><strong>Autor:</strong> @Model.Autor</p>
                <p><strong>Género:</strong> @Model.Genero</p>
                <p><strong>Año de Publicación:</strong> @Model.AnioPublicacion</p>
            </div>

            <p class="text-warning">¿Está seguro de que desea eliminar este libro?</p>

            <form asp-action="Destroy" method="post" class="d-flex flex-column align-items-center">

                <input type="hidden" asp-for="Id" />

                <div class="mt-3 d-flex gap-3">
                    <button type="submit" class="btn btn-danger">Eliminar</button>

                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>

            </form>

        </div>
    </div>

</div>