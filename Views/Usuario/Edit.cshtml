@model BookstoreSistem.Models.Usuario

<div class="content vh-100 d-flex align-items-center justify-content-center">
    <div class="row">
        <div class="col-lg-12 shadow shadow-lg p-5 justify-content-center align-items-center d-flex flex-column">
            <h2>Editar Usuario</h2>
            <form asp-action="Edit" method="post" class="form d-flex flex-column align-items-center justify-content-center">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="form-group mt-3">
                    <label asp-for="Nombre"></label>
                    <input asp-for="Nombre" class="form-control" />
                </div>

                <div class="form-group mt-3">
                    <label asp-for="Apellido"></label>
                    <input asp-for="Apellido" class="form-control" />
                </div>

                <div class="form-group mt-3">
                    <label asp-for="Edad"></label>
                    <input asp-for="Edad" class="form-control" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Actualizar</button>
                </div>
            </form>
        </div>
    </div>
</div>